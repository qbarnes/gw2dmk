root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,h}]
indent_style = tab
indent_size = 8
max_line_length = 80

[{Makefile,Makefile.*,*.mk}]
indent_style = tab
indent_size = 8

[*.{1..8}]
indent_style = tab
indent_size = 8

[*.yml]
indent_style = space
indent_size = 2
